# TechStore Vietnam ETL Pipeline - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Path to Google Cloud service account JSON key file
GOOGLE_CREDENTIALS_PATH=config/your-service-account-key.json

# GCP Project and Dataset
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET_ID=techstore_analytics

# GCS Bucket
GCS_BUCKET_NAME=minpy
